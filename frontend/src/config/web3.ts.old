// Configuration AppKit
const projectId = '8e4b1bfd9a610fec9db0a70d7bbbd67e' // TODO: Ajouter ton Project ID Reown

const networks = [monadTestnet]
const metadata = {
  name: 'Spin Brigade',
  description: 'Join the culinary revolution on Monad!',
  url: 'https://spin-brigade.xyz',
  icons: ['/logo.png']
}

const ethersAdapter = new EthersAdapter()

export const appKit = createAppKit({
  adapters: [ethersAdapter],
  networks,
  metadata,
  projectId,
  features: {
    analytics: true,
    email: true,
    socials: ['google', 'x', 'github', 'discord'],
  }
})
