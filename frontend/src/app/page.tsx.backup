'use client'

import { useState } from 'react'

export default function Home() {
  const [count, setCount] = useState(0)
  
  return (
    <div style={{
      minHeight: '100vh',
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      justifyContent: 'center',
      padding: '2rem',
      textAlign: 'center'
    }}>
      <h1 style={{
        fontSize: '4rem',
        fontWeight: '900',
        color: '#1f2937',
        marginBottom: '1rem'
      }}>
        ⚡ Spin Brigade
      </h1>
      
      <p style={{
        fontSize: '1.5rem',
        color: '#6b7280',
        marginBottom: '2rem'
      }}>
        Frontend is working! 🎉
      </p>

      <div style={{
        background: '#dcfce7',
        color: '#166534',
        padding: '1rem 2rem',
        borderRadius: '1rem',
        marginBottom: '2rem'
      }}>
        ✅ Server is responding correctly
      </div>

      <button 
        onClick={() => setCount(count + 1)}
        style={{
          background: 'linear-gradient(90deg, #9333ea, #ec4899)',
          color: 'white',
          border: 'none',
          padding: '1rem 2rem',
          borderRadius: '2rem',
          fontSize: '1.1rem',
          fontWeight: 'bold',
          cursor: 'pointer'
        }}
      >
        Test Button (clicked {count} times)
      </button>

      <div style={{ marginTop: '2rem', fontSize: '0.9rem', color: '#6b7280' }}>
        <p>Next step: Add Web3 functionality</p>
